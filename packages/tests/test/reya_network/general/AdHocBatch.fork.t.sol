pragma solidity >=0.8.19 <0.9.0;

import { ReyaForkTest } from "../ReyaForkTest.sol";

import { ICoreProxy, GlobalCollateralConfig } from "../../../src/interfaces/ICoreProxy.sol";
import { ITokenProxy } from "../../../src/interfaces/ITokenProxy.sol";

// Ad-hoc verification of the EXACT multisig batch calldata before it is
// submitted on-chain. Unlike a Cannon `invoke` (which re-encodes from
// func+args), this replays the literal bytes via a low-level call, so it
// proves the data you will actually send is correct.
//
// The on-chain tx is sent TO the multisig itself (selector 0x174dea71 wrapping
// 5 calls: approve USDC->RUSD, deposit RUSD, approve RUSD->pool,
// setGlobalCollateralConfig(RAMBER), triggerAutoRebalance(poolId=1, ...->RAMBER)).
//
// Runs in the normal `cannon test ... --forge.match-path test/reya_network/**`
// flow, i.e. AFTER the deployment is applied to the fork.
// DISABLED — superseded by the Cannon TOML invokes in
// tomls/src/omnibus/utils/adhoc_ramber_rebalance_test.toml, which apply the
// batch to the shared fork state so the whole suite runs on top of it. This
// file is kept only as a standalone exact-bytes check; its test function is
// intentionally NOT prefixed with `test` so Forge skips it (running it here
// would double-apply the batch and fail). Safe to delete.
contract AdHocBatchForkTest is ReyaForkTest {
    // The address authorized to submit the batch to the multisig. The on-chain
    // tx is sent to the multisig; impersonate the multisig itself (self-call).
    // If the executor enforces a specific signer/owner and this reverts with an
    // auth error, change this to that signer.
    address constant BATCH_CALLER = 0x1Fe50318e5E3165742eDC9c4a15d997bDB935Eb9;

    // The exact calldata sent on-chain (selector 0x174dea71 + 5 wrapped calls).
    bytes constant BATCH_CALLDATA =
        hex"";

    function test_AdHoc_RamberRebalanceBatch() public {
        // Sanity: the multisig should hold >= 250k USDC on the fork to wrap.
        uint256 usdcBefore = ITokenProxy(sec.usdc).balanceOf(sec.multisig);
        assertGe(usdcBefore, 250_000e6, "multisig lacks USDC on fork");

        uint256 ramberBefore = ITokenProxy(sec.ramber).balanceOf(sec.multisig);

        // Send the EXACT on-chain calldata to the multisig.
        vm.prank(BATCH_CALLER);
        (bool ok, bytes memory ret) = sec.multisig.call(BATCH_CALLDATA);
        require(ok, _revertReason(ret));

        // Tx4 effect: RAMBER global collateral config was overwritten.
        (GlobalCollateralConfig memory cfg,) = ICoreProxy(sec.core).getGlobalCollateralConfig(sec.ramber);
        assertEq(cfg.collateralAdapter, address(0), "ramber adapter");
        assertEq(cfg.withdrawalWindowSize, 0, "ramber window");
        assertEq(cfg.withdrawalTvlPercentageLimit, 1e18, "ramber tvl limit");

        // Tx5 effect: auto-rebalance sent RAMBER (tokenOut) to the multisig (receiver).
        uint256 ramberAfter = ITokenProxy(sec.ramber).balanceOf(sec.multisig);
        assertGt(ramberAfter, ramberBefore, "multisig did not receive RAMBER");

        // The 250k USDC was wrapped into RUSD and consumed.
        assertEq(ITokenProxy(sec.usdc).balanceOf(sec.multisig), usdcBefore - 250_000e6, "USDC not consumed");
    }

    function _revertReason(bytes memory ret) private pure returns (string memory) {
        if (ret.length == 0) return "batch call reverted (no reason)";
        return string(ret);
    }
}
